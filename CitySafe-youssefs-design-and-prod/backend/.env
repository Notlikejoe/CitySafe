# Backend Environment — copy this to .env and fill in your values
PORT=4005
NODE_ENV=development

# JWT Secret — use a strong random string in production (e.g. openssl rand -base64 64)
JWT_SECRET=citysafe-dev-secret-change-in-prod-v2

# Set to "true" to persist in-memory store to disk as JSON between restarts
PERSIST_STORE=true
